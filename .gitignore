# =========================
# Python
# =========================
__pycache__/
*.pyc
*.pyo
*.pyd
*.sqlite3
*.log

# Virtual Environment
venv/
.env/
.env.*

# =========================
# Data (keep structure only)
# =========================
data/raw_midi/*
data/processed/*
data/train_test_split/*

# allow placeholders (.md or .gitkeep)
!data/raw_midi/**/
!data/raw_midi/**/*.md
!data/raw_midi/**/*.gitkeep

!data/processed/
!data/processed/*.md
!data/processed/.gitkeep

!data/train_test_split/
!data/train_test_split/*.md
!data/train_test_split/.gitkeep

# =========================
# Model Checkpoints
# =========================
checkpoints/*
!checkpoints/*.md
!checkpoints/.gitkeep

# =========================
# Outputs
# =========================
outputs/*
!outputs/**/
!outputs/**/*.md
!outputs/**/*.gitkeep

# =========================
# Jupyter
# =========================
.ipynb_checkpoints/

# =========================
# OS / Editor
# =========================
.DS_Store
Thumbs.db
.vscode/
.idea/

# =========================
# Large files (optional)
# =========================
*.mid
*.midi
*.wav
*.mp3

# =========================
# Keep documentation files
# =========================
!*.md